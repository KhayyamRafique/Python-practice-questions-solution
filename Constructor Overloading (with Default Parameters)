
# Concept: Constructor Overloading (with Default Parameters)
# Q7. Create a class that allows the constructor to work with:
# • name only
# • name + age
# • name + age + address
# As direct constructor overloading (multiple constructors) are not allowed but
# we have to use default parameters to simulate constructor overloading.


class person:
    def __init__(self,name,age=56,adress=345):
        self.name  = name
        self.age = age
        self.adress = adress
    def desply (self):
        print(f"The name of student is {self.name} and its age is {self.age}. The adress of the student is {self.adress}")
    
p = person("khayyam","45","345")
p.desply()
