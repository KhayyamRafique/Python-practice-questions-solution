
# Concept: Multiple Inheritance
# Q9. Create the following classes: Herbivore , Carnivore , with some
# attributes & methods. Then create a class Bear that inherits from all the above
# classes to showcase how multiple inheritance works.

class Herbivore:
    def __init__(self,eat_plant):
        self.eat_plant  = eat_plant
    def eat_plants(self):
        print(f"Eating {self.eat_plant}")
class Carnivore:
    def __init__(self,eat_meat):
        self.eat_meat  = eat_meat
    def eat_Meat(self):
        print(f"Eating {self.eat_meat}")
class Bear(Herbivore,Carnivore):
    def __init__(self, eat_plant,eat_meat):
        Herbivore.__init__(self, eat_plant)
        Carnivore.__init__(self, eat_meat)
        self.eat_meat  = eat_meat
        self.eat_plant = eat_plant
    def display(self):
        print(f"the Herbivore eat {self.eat_plant} and Carnvore eat {self.eat_meat}")
    
b = Bear("flowers","muton")
b.eat_plants()
b.eat_Meat()
b.display()
